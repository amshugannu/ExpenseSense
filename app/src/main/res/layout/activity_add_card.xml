<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".AddCardActivity">

    <!-- Header Image -->
    <ImageView
        android:id="@+id/imgHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitXY"
        android:src="@drawable/activityheaderbg" />

    <!-- Header Controls -->
    <RelativeLayout
        android:id="@+id/headerControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/imgHeader"
        android:layout_alignBottom="@id/imgHeader">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="8dp"
            android:layout_marginTop="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="56dp"
            android:text="Add Card"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold|italic" />

    </RelativeLayout>

    <!-- Fixed Save Button at Bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveCard"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="28dp"
        android:text="Save Card"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/color_teal_primary"
        app:cornerRadius="30dp"
        app:elevation="8dp" />

    <!-- Scrollable Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnSaveCard"
        android:layout_below="@id/imgHeader"
        android:layout_marginTop="-100dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ===================== CARD: Step 1 – Bank Selection ===================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Step label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEP 1 — SELECT BANK"
                        android:textColor="@color/color_teal_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        style="@style/LabelStyle"
                        android:layout_marginTop="12dp"
                        android:text="BANK NAME" />

                    <!-- Bank Spinner -->
                    <Spinner
                        android:id="@+id/spinnerBank"
                        style="@style/FieldStyle"
                        android:layout_marginTop="4dp" />

                    <!-- Custom Bank Name (shown only when "Other" selected) -->
                    <LinearLayout
                        android:id="@+id/layoutCustomBank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="16dp"
                            android:text="ENTER BANK NAME" />

                        <EditText
                            android:id="@+id/etCustomBankName"
                            style="@style/FieldStyle"
                            android:hint="e.g. Yes Bank"
                            android:inputType="textCapWords" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===================== CARD: Step 2 – Card Type ===================== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStepType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEP 2 — CARD TYPE"
                        android:textColor="@color/color_teal_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        style="@style/LabelStyle"
                        android:layout_marginTop="12dp"
                        android:text="CARD TYPE" />

                    <Spinner
                        android:id="@+id/spinnerCardType"
                        style="@style/FieldStyle"
                        android:entries="@array/card_types_step"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===================== CARD: Step 3 – Card Selection (Predefined) ===================== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStepPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEP 3 — SELECT CARD"
                        android:textColor="@color/color_teal_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        style="@style/LabelStyle"
                        android:layout_marginTop="8dp"
                        android:text="CHOOSE YOUR CARD" />

                    <!-- Horizontal card options RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCardOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:paddingEnd="8dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                    <!-- Custom card name (shown only when "Other Card" selected) -->
                    <LinearLayout
                        android:id="@+id/layoutCustomCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="16dp"
                            android:text="CARD NAME" />

                        <EditText
                            android:id="@+id/etCustomCardName"
                            style="@style/FieldStyle"
                            android:hint="e.g. Amazon Pay Credit Card"
                            android:inputType="textCapWords" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===================== CARD: Step 3 (Other bank) – Custom Card Details ===================== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStepOtherBankCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEP 3 — CARD DETAILS"
                        android:textColor="@color/color_teal_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        style="@style/LabelStyle"
                        android:layout_marginTop="12dp"
                        android:text="CARD NAME" />

                    <EditText
                        android:id="@+id/etOtherBankCardName"
                        style="@style/FieldStyle"
                        android:hint="e.g. Yes Bank Savings Debit"
                        android:inputType="textCapWords" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===================== CARD: Step 4 – Card Holder Info ===================== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStepDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEP 4 — CARD INFO"
                        android:textColor="@color/color_teal_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- Name on Card -->
                    <TextView
                        style="@style/LabelStyle"
                        android:layout_marginTop="12dp"
                        android:text="NAME ON CARD" />

                    <EditText
                        android:id="@+id/etCardHolderName"
                        style="@style/FieldStyle"
                        android:hint="Full Name"
                        android:inputType="textCapWords" />

                    <!-- Card Number -->
                    <TextView
                        style="@style/LabelStyle"
                        android:layout_marginTop="20dp"
                        android:text="CARD NUMBER" />

                    <EditText
                        android:id="@+id/etCardNumber"
                        style="@style/FieldStyle"
                        android:hint="XXXX XXXX XXXX XXXX"
                        android:inputType="number"
                        android:maxLength="16" />

                    <!-- ========= Credit-only fields ========= -->
                    <LinearLayout
                        android:id="@+id/layoutCreditFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="20dp"
                            android:text="TOTAL CREDIT LIMIT" />

                        <EditText
                            android:id="@+id/etCreditLimit"
                            style="@style/FieldStyle"
                            android:hint="₹ 0.00"
                            android:inputType="numberDecimal" />

                        <TextView
                            style="@style/LabelStyle"
                            android:layout_marginTop="20dp"
                            android:text="AVAILABLE LIMIT" />

                        <EditText
                            android:id="@+id/etAvailableLimit"
                            style="@style/FieldStyle"
                            android:hint="₹ 0.00"
                            android:inputType="numberDecimal" />

                    </LinearLayout>

                    <!-- ========= Debit-only fields ========= -->
                    <LinearLayout
                        android:id="@+id/layoutDebitFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <CheckBox
                            android:id="@+id/cbAddBankAccount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:checked="true"
                            android:text="Also add the linked bank account"
                            android:textColor="#2C2C2C" />

                        <LinearLayout
                            android:id="@+id/layoutNewAccount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                style="@style/LabelStyle"
                                android:layout_marginTop="16dp"
                                android:text="INITIAL BALANCE" />

                            <EditText
                                android:id="@+id/etAccountBalance"
                                style="@style/FieldStyle"
                                android:hint="₹ 0.00"
                                android:inputType="numberDecimal" />

                            <TextView
                                style="@style/LabelStyle"
                                android:layout_marginTop="20dp"
                                android:text="ACCOUNT TYPE" />

                            <Spinner
                                android:id="@+id/spinnerAccountType"
                                style="@style/FieldStyle"
                                android:entries="@array/account_types" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
